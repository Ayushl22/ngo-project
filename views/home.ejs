<% layout('layout') -%>
<div class="home-hero">
  <h1>NGO Platform</h1>
  <p class="hero-subtitle">Connect, volunteer, and make an impact in your community.</p>
</div>
<section class="features-grid">
  <a href="/events" class="feature-card">
    <h3>Browse Events</h3>
    <p>View all upcoming events and find opportunities to get involved.</p>
  </a>
  <a href="/events/new" class="feature-card">
    <h3>Create Event</h3>
    <p>Organize a new event and invite volunteers to participate.</p>
  </a>
  <a href="/register" class="feature-card">
    <h3>Register</h3>
    <p>Create an account to join the platform and participate in events.</p>
  </a>
  <a href="/login" class="feature-card">
    <h3>Login</h3>
    <p>Sign in to your account to manage events and track your activity.</p>
  </a>
</section>
