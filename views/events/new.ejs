<% layout('layout') -%>
<h1 class="page-title">Create Event</h1>
<form action="/events" method="POST" class="card">
  <div class="form-group">
    <label for="title">Title</label>
    <input type="text" id="title" name="event[title]" class="form-control" placeholder="Event title" required>
  </div>
  <div class="form-group">
    <label for="location">Location</label>
    <input type="text" id="location" name="event[location]" class="form-control" placeholder="Event location">
  </div>
  <div class="form-group">
    <label for="description">Description</label>
    <textarea id="description" name="event[description]" class="form-control" placeholder="Describe the event"></textarea>
  </div>
  <div class="form-group">
    <label for="date">Date</label>
    <input type="date" id="date" name="event[date]" class="form-control">
  </div>
  <button type="submit" class="btn btn-primary">Create Event</button>
</form>
